<%- include('../partial/head') %>
<div class="layout-wrapper">
  <%- include('../partial/navbar') %>
  <div class="main-content">
    <div class="page-header">
      <h4 class="page-title"><i class="bi bi-cash-register me-2"></i>Kasir</h4>
      <span class="text-muted small" id="live-clock"></span>
    </div>

    <%- include('../partial/flash') %>

    <div class="kasir-layout">
      <!-- Panel Kiri: Menu -->
      <div class="menu-section">
        <div class="filter-bar mb-3">
          <button class="btn btn-filter active" data-kat="semua">Semua</button>
          <% kategoris.forEach(k => { %>
            <button class="btn btn-filter" data-kat="<%= k.KategoriID %>"><%= k.NamaKategori %></button>
          <% }) %>
        </div>

        <div class="menu-grid" id="menu-grid">
          <% menus.forEach(m => { %>
            <div class="menu-card <%= m.Status === 'Habis' ? 'out-of-stock' : '' %>"
                 data-kat="<%= m.KategoriID %>"
                 data-id="<%= m.MenuID %>"
                 data-nama="<%= m.NamaMenu %>"
                 data-harga="<%= m.Harga %>"
                 data-stok="<%= m.Stok %>"
                 onclick="<%= m.Status !== 'Habis' ? 'addToCart(this)' : '' %>">
              <div class="menu-card-body">
                <div class="menu-name"><%= m.NamaMenu %></div>
                <div class="menu-kategori"><%= m.NamaKategori %></div>
                <div class="menu-price">Rp <%= parseInt(m.Harga).toLocaleString('id-ID') %></div>
                <div class="menu-stok">
                  <% if (m.Status === 'Habis') { %>
                    <span class="badge bg-danger">Habis</span>
                  <% } else if (m.Stok <= 5) { %>
                    <span class="badge bg-warning text-dark">Stok: <%= m.Stok %></span>
                  <% } else { %>
                    <span class="badge bg-success">Stok: <%= m.Stok %></span>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <!-- Panel Kanan: Order -->
      <div class="order-section">
        <div class="order-header">
          <span class="fw-semibold">Pesanan</span>
          <span class="text-muted small" id="order-num">#001</span>
        </div>

        <div class="order-items" id="order-items">
          <div class="order-empty" id="order-empty">
            <i class="bi bi-cart3" style="font-size:2rem;color:#ccc"></i>
            <p class="text-muted small mt-2">Pilih menu untuk menambah pesanan</p>
          </div>
        </div>

        <div class="order-footer">
          <div class="total-section">
            <span class="total-label">Total</span>
            <span class="total-amount" id="total-display">Rp 0</span>
          </div>

          <div class="mb-2">
            <label class="form-label small">Metode Bayar</label>
            <select class="form-select form-select-sm" id="metode-bayar">
              <option value="Tunai">Tunai</option>
              <option value="QRIS">QRIS</option>
              <option value="Transfer">Transfer Bank</option>
            </select>
          </div>

          <div class="mb-2" id="bayar-section">
            <label class="form-label small">Uang Diterima</label>
            <input type="number" class="form-control form-control-sm" id="uang-bayar"
                   placeholder="0" oninput="calcChange()">
          </div>

          <div class="change-row" id="change-row">
            <span class="small text-muted">Kembalian</span>
            <span class="fw-semibold text-success" id="kembalian-display">Rp 0</span>
          </div>

          <button class="btn btn-noburi w-100 mt-2" id="btn-bayar" onclick="processPayment()" disabled>
            <i class="bi bi-check-circle me-1"></i> Proses Bayar
          </button>
          <button class="btn btn-outline-secondary w-100 mt-2 btn-sm" onclick="clearOrder()">
            <i class="bi bi-trash me-1"></i> Batal / Reset
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal Struk -->
<div class="modal fade" id="modalStruk" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header border-0">
        <h6 class="modal-title">Transaksi Berhasil</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center" id="struk-content"></div>
      <div class="modal-footer border-0">
        <button class="btn btn-noburi w-100" data-bs-dismiss="modal" onclick="resetAfterPay()">
          <i class="bi bi-plus-circle me-1"></i> Transaksi Berikutnya
        </button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
let cart = [];
let orderCount = 1;

function fmt(n) {
  return 'Rp ' + parseInt(n).toLocaleString('id-ID');
}

// Clock
function updateClock() {
  const now = new Date();
  document.getElementById('live-clock').textContent =
    now.toLocaleDateString('id-ID', {weekday:'long', year:'numeric', month:'long', day:'numeric'}) +
    ' ' + now.toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'});
}
updateClock();
setInterval(updateClock, 1000);

// Filter kategori
document.querySelectorAll('.btn-filter').forEach(btn => {
  btn.addEventListener('click', function () {
    document.querySelectorAll('.btn-filter').forEach(b => b.classList.remove('active'));
    this.classList.add('active');
    const kat = this.dataset.kat;
    document.querySelectorAll('.menu-card').forEach(card => {
      card.style.display = (kat === 'semua' || card.dataset.kat === kat) ? 'flex' : 'none';
    });
  });
});

// Add to cart
function addToCart(el) {
  const id = el.dataset.id;
  const nama = el.dataset.nama;
  const harga = parseInt(el.dataset.harga);
  const stok = parseInt(el.dataset.stok);
  const inCart = cart.find(i => i.MenuID === id);
  const qtyInCart = inCart ? inCart.Qty : 0;
  if (qtyInCart >= stok) { showAlert('Stok tidak cukup!', 'warning'); return; }
  if (inCart) {
    inCart.Qty++;
    inCart.Subtotal = inCart.Qty * inCart.Harga;
  } else {
    cart.push({ MenuID: id, NamaMenu: nama, Harga: harga, Qty: 1, Subtotal: harga });
  }
  renderCart();
}

function changeQty(id, delta) {
  const idx = cart.findIndex(i => i.MenuID === id);
  if (idx < 0) return;
  cart[idx].Qty += delta;
  if (cart[idx].Qty <= 0) cart.splice(idx, 1);
  else cart[idx].Subtotal = cart[idx].Qty * cart[idx].Harga;
  renderCart();
}

function renderCart() {
  const container = document.getElementById('order-items');
  const empty = document.getElementById('order-empty');
  const total = cart.reduce((s, i) => s + i.Subtotal, 0);

  if (cart.length === 0) {
    empty.style.display = 'block';
    container.querySelectorAll('.cart-item').forEach(el => el.remove());
  } else {
    empty.style.display = 'none';
    const existing = container.querySelectorAll('.cart-item');
    existing.forEach(el => el.remove());
    cart.forEach(item => {
      const div = document.createElement('div');
      div.className = 'cart-item';
      div.innerHTML = `
        <div class="cart-item-name">${item.NamaMenu}</div>
        <div class="cart-item-controls">
          <button class="qty-btn" onclick="changeQty('${item.MenuID}', -1)">-</button>
          <span class="qty-num">${item.Qty}</span>
          <button class="qty-btn" onclick="changeQty('${item.MenuID}', 1)">+</button>
          <span class="cart-subtotal">${fmt(item.Subtotal)}</span>
        </div>`;
      container.appendChild(div);
    });
  }

  document.getElementById('total-display').textContent = fmt(total);
  document.getElementById('btn-bayar').disabled = cart.length === 0;
  calcChange();
}

function calcChange() {
  const total = cart.reduce((s, i) => s + i.Subtotal, 0);
  const bayar = parseInt(document.getElementById('uang-bayar').value) || 0;
  const kembalian = bayar - total;
  document.getElementById('kembalian-display').textContent = fmt(Math.max(0, kembalian));
  document.getElementById('btn-bayar').disabled =
    cart.length === 0 || (document.getElementById('metode-bayar').value === 'Tunai' && bayar < total);
}

document.getElementById('metode-bayar').addEventListener('change', function () {
  const isTunai = this.value === 'Tunai';
  document.getElementById('bayar-section').style.display = isTunai ? 'block' : 'none';
  document.getElementById('change-row').style.display = isTunai ? 'flex' : 'none';
  if (!isTunai) document.getElementById('btn-bayar').disabled = cart.length === 0;
  else calcChange();
});

function clearOrder() {
  cart = [];
  document.getElementById('uang-bayar').value = '';
  renderCart();
}

async function processPayment() {
  const total = cart.reduce((s, i) => s + i.Subtotal, 0);
  const metode = document.getElementById('metode-bayar').value;
  const bayar = metode === 'Tunai' ? parseInt(document.getElementById('uang-bayar').value) : total;

  if (metode === 'Tunai' && bayar < total) {
    showAlert('Uang yang diterima kurang!', 'danger');
    return;
  }

  document.getElementById('btn-bayar').disabled = true;
  document.getElementById('btn-bayar').innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Memproses...';

  try {
    const res = await fetch('/kasir/transaksi', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        items: JSON.stringify(cart),
        totalHarga: total,
        totalBayar: bayar,
        metodeBayar: metode
      })
    });
    const data = await res.json();
    if (data.success) {
      showStruk(data.transaksiID, total, bayar, data.kembalian, metode);
    } else {
      showAlert('Gagal: ' + data.message, 'danger');
      document.getElementById('btn-bayar').disabled = false;
      document.getElementById('btn-bayar').innerHTML = '<i class="bi bi-check-circle me-1"></i> Proses Bayar';
    }
  } catch (e) {
    showAlert('Error koneksi', 'danger');
  }
}

function showStruk(id, total, bayar, kembalian, metode) {
  const now = new Date().toLocaleString('id-ID');
  document.getElementById('struk-content').innerHTML = `
    <div class="struk">
      <div class="struk-brand">NoBuRi</div>
      <small class="text-muted">Rice Burger Bandung</small>
      <hr>
      <div class="text-start small">
        <div><b>No:</b> ${id}</div>
        <div><b>Waktu:</b> ${now}</div>
        <div><b>Kasir:</b> <%= user.NamaUser %></div>
        <div><b>Metode:</b> ${metode}</div>
      </div>
      <hr>
      <table class="w-100 small text-start">
        ${cart.map(i => `<tr><td>${i.NamaMenu} x${i.Qty}</td><td class="text-end">${fmt(i.Subtotal)}</td></tr>`).join('')}
      </table>
      <hr>
      <div class="d-flex justify-content-between"><b>Total</b><b>${fmt(total)}</b></div>
      ${metode === 'Tunai' ? `
      <div class="d-flex justify-content-between small"><span>Bayar</span><span>${fmt(bayar)}</span></div>
      <div class="d-flex justify-content-between small text-success"><span>Kembalian</span><span>${fmt(kembalian)}</span></div>` : ''}
      <hr>
      <small class="text-muted">Terima kasih sudah mampir!</small>
    </div>`;
  new bootstrap.Modal(document.getElementById('modalStruk')).show();
}

function resetAfterPay() {
  cart = [];
  document.getElementById('uang-bayar').value = '';
  document.getElementById('btn-bayar').innerHTML = '<i class="bi bi-check-circle me-1"></i> Proses Bayar';
  renderCart();
  // Reload stok data
  location.reload();
}

function showAlert(msg, type) {
  const a = document.createElement('div');
  a.className = `alert alert-${type} alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3`;
  a.style.zIndex = 9999;
  a.innerHTML = msg + `<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
  document.body.appendChild(a);
  setTimeout(() => a.remove(), 3000);
}
</script>
</body></html>
