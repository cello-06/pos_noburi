<%- include('../partial/head') %>
<div class="layout-wrapper">
  <%- include('../partial/navbar') %>
  <div class="main-content">
    <div class="page-header">
      <h4 class="page-title"><i class="bi bi-bar-chart-line me-2"></i>Laporan Penjualan</h4>
    </div>

    <%- include('../partial/flash') %>

    <!-- Summary Hari Ini -->
    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-label">Total Penjualan Hari Ini</div>
          <div class="stat-value">Rp <%= parseInt(summaryToday.totalPenjualan).toLocaleString('id-ID') %></div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-label">Jumlah Transaksi</div>
          <div class="stat-value"><%= summaryToday.totalTrx %> <small class="text-muted fs-6">pesanan</small></div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-label">Rata-rata per Transaksi</div>
          <div class="stat-value">Rp <%= parseInt(summaryToday.rataRata).toLocaleString('id-ID') %></div>
        </div>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <!-- Filter Tanggal -->
      <div class="col-md-8">
        <div class="card-noburi">
          <h6 class="fw-semibold mb-3">Filter Riwayat Transaksi</h6>
          <form method="GET" class="row g-2 align-items-end">
            <div class="col-md-5">
              <label class="form-label small">Dari Tanggal</label>
              <input type="date" name="dari" class="form-control form-control-sm" value="<%= tglDari %>">
            </div>
            <div class="col-md-5">
              <label class="form-label small">Sampai Tanggal</label>
              <input type="date" name="sampai" class="form-control form-control-sm" value="<%= tglSampai %>">
            </div>
            <div class="col-md-2">
              <button type="submit" class="btn btn-noburi btn-sm w-100">Cari</button>
            </div>
          </form>
        </div>
      </div>

      <!-- Menu Terlaris -->
      <div class="col-md-4">
        <div class="card-noburi h-100">
          <h6 class="fw-semibold mb-3">Menu Terlaris</h6>
          <% if (terlaris.length === 0) { %>
            <p class="text-muted small">Belum ada data</p>
          <% } else { %>
            <% terlaris.forEach((t, i) => { %>
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="d-flex align-items-center gap-2">
                  <span class="badge bg-noburi"><%= i + 1 %></span>
                  <span class="small"><%= t.NamaMenu %></span>
                </div>
                <span class="small fw-semibold"><%= t.totalQty %> pcs</span>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Tabel Transaksi -->
    <div class="card-noburi">
      <h6 class="fw-semibold mb-3">
        Riwayat Transaksi
        <span class="text-muted fw-normal small">(<%= tglDari %> s/d <%= tglSampai %>)</span>
      </h6>
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>ID Transaksi</th>
            <th>Waktu</th>
            <th>Kasir</th>
            <th>Metode</th>
            <th>Total</th>
            <th>Status</th>
            <th>Detail</th>
          </tr>
        </thead>
        <tbody>
          <% if (transaksis.length === 0) { %>
          <tr><td colspan="7" class="text-center text-muted py-4">Tidak ada transaksi pada periode ini</td></tr>
          <% } %>
          <% transaksis.forEach(t => { %>
          <tr>
            <td><code><%= t.TransaksiID %></code></td>
            <td class="small"><%= new Date(t.TanggalTransaksi).toLocaleString('id-ID') %></td>
            <td><%= t.NamaUser %></td>
            <td><span class="badge bg-secondary"><%= t.MetodeBayar %></span></td>
            <td class="fw-semibold">Rp <%= parseInt(t.TotalHarga).toLocaleString('id-ID') %></td>
            <td>
              <span class="badge <%= t.Status === 'Selesai' ? 'bg-success' : 'bg-danger' %>">
                <%= t.Status %>
              </span>
            </td>
            <td>
              <a href="/laporan/detail/<%= t.TransaksiID %>" class="btn btn-xs btn-outline-primary">
                <i class="bi bi-eye"></i>
              </a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body></html>
